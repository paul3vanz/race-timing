# Copy this to .env (or .env.local) and fill in real values, then restart
# `expo start` so the new EXPO_PUBLIC_* vars get picked up.
#
# Run `supabase status` (from the repo root, with `supabase start` already
# running) to get the local API URL and anon key.
#
# Reaching a locally-running Supabase from the app depends on where the app
# runs — 127.0.0.1 only works when the app itself runs on the same machine
# (web, or an iOS simulator on the same Mac):
#   - Android emulator  -> use 10.0.2.2 instead of 127.0.0.1
#   - Physical device    -> use your machine's LAN IP (e.g. 192.168.1.23)
#   - Hosted project     -> use the project URL from the Supabase dashboard
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status
